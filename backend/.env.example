# ===== DATABASE =====
# Produção (Railway): SQLite em volume persistente montado em /data
#   -> definido no Dockerfile: DATABASE_URL=sqlite:////data/estoque_virtual.db
# Desenvolvimento local: SQLite no diretório do backend
DATABASE_URL=sqlite:///./estoque_virtual.db
# Alternativa (caso migre para Postgres):
# DATABASE_URL=postgresql://user:password@host:5432/estoque_virtual

# ===== UPLOADS =====
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=xml,pdf
MAX_FILE_SIZE=10485760

# ===== OLIST INTEGRATION =====
# Token API Simples (Tiny)
OLIST_API_TOKEN_SIMPLE=sua_chave_aqui

# OAuth2 Credentials
OLIST_CLIENT_ID=seu_client_id
OLIST_CLIENT_SECRET=seu_client_secret
OLIST_REDIRECT_URI=https://sua-api.railway.app/api/olist/callback

# ===== GENERAL =====
DEBUG=False
